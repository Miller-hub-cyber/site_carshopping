# CarShopping — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# ===== BANCO DE DADOS =====
# Neon (produção):  postgresql://user:pass@ep-xxx.neon.tech/carshopping?sslmode=require
# Local:            postgresql://postgres:SUA_SENHA@localhost:5432/carshopping
DATABASE_URL="postgresql://postgres:SENHA@localhost:5432/carshopping"

# ===== AUTENTICAÇÃO =====
# Gere em: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria"

# ===== SERVIDOR =====
PORT=3000
NODE_ENV=development

# ===== CORS (produção) =====
# URLs do frontend separadas por vírgula
# CORS_ORIGIN=https://carshopping.netlify.app,https://www.seudominio.com
CORS_ORIGIN=

# ===== EMAIL via Resend (opcional) =====
# Crie conta em https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=CarShopping <noreply@seudominio.com>
# ADMIN_EMAIL=seu@email.com

# ===== IMAGENS via Cloudinary (recomendado para produção) =====
# Crie conta em https://cloudinary.com, copie a "API Environment variable"
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
